{
  "manifest_version": 3,
  "name": "NexusChats",
  "short_name": "NexusChats",
  "description": "Local productivity controls for the ChatGPT sidebar.",
  "version": "0.2.0",
  "action": {
    "default_title": "NexusChats"
  },
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": ["https://chatgpt.com/*"],
      "js": ["assets/content.js"],
      "css": ["assets/content.css"],
      "run_at": "document_idle"
    }
  ]
}
