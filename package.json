{
  "name": "nexuschats",
  "version": "0.2.0",
  "description": "A local, open-source Chrome extension that adds productivity controls to the ChatGPT sidebar.",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "vite build --watch --mode development",
    "build": "tsc --noEmit && vite build",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "verify": "npm run format:check && npm run lint && npm run test && npm run build"
  },
  "keywords": [
    "chrome-extension",
    "chatgpt",
    "productivity",
    "typescript",
    "manifest-v3"
  ],
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/chrome": "^0.0.270",
    "@types/node": "^20.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.1.0",
    "globals": "^15.0.0",
    "prettier": "^3.3.0",
    "typescript": "^7.0.2",
    "typescript-eslint": "^8.0.0",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  }
}
